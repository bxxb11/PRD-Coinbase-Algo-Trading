# Exchange credentials (only required when PAPER_TRADING=False)
COINBASE_API_KEY=your_api_key_here
COINBASE_API_SECRET=your_api_secret_here

# Mode — default ON for safety, set False only after paper testing
PAPER_TRADING=True

# Market
TRADING_PAIR=BTC/USD
TIMEFRAME=1h
CANDLES_REQUIRED=100
LOOP_INTERVAL_SECONDS=60
# SCHEDULED_HOURS=2,14     # optional: tick at 02:00 + 14:00 UTC instead of fixed interval
#                           # leave blank to use LOOP_INTERVAL_SECONDS above

# ── Strategy selector ─────────────────────────────────────────────────────────
# Options: ma_crossover | macd | ema_rsi | supertrend | donchian_adx
STRATEGY=ema_rsi

# EMA+RSI params (active when STRATEGY=ema_rsi) — 2025-2026 sweep-optimised defaults
EMA_SHORT=21
EMA_LONG=34
RSI_PERIOD=21
RSI_BUY_THRESH=45.0
RSI_SELL_THRESH=55.0
TREND_CONFIRM_BARS=3

# MACD params (active when STRATEGY=macd)
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL_PERIOD=9
MACD_ZERO_FILTER=True

# SuperTrend params (active when STRATEGY=supertrend)
ATR_PERIOD=10
ATR_MULTIPLIER=3.0

# Donchian + ADX params (active when STRATEGY=donchian_adx)
# Sweep-optimal on 1h bars: 2-day entry breakout / 10-day trailing exit
DC_ENTER_BARS=48
DC_EXIT_BARS=240
ADX_PERIOD=14
ADX_THRESHOLD=25.0

# MA Crossover params (active when STRATEGY=ma_crossover)
MA_SHORT_PERIOD=20
MA_LONG_PERIOD=50

# ── Sizing ($1–$20 per trade, driven by MA20/50 spread strength) ──────────────
MIN_TRADE_SIZE_USD=1.0
MAX_TRADE_SIZE_USD=20.0
SIZE_SPREAD_MIN_PCT=0.1
SIZE_SPREAD_MAX_PCT=0.5
MAX_POSITION_USD=200.0

# ── Risk ──────────────────────────────────────────────────────────────────────
MAX_DRAWDOWN_PERCENT=25.0
INITIAL_EQUITY_USD=1000.0

# ── Persistence & Logging ─────────────────────────────────────────────────────
DB_PATH=state/trading.db
LOG_DIR=logs/
LOG_LEVEL=INFO
